+    #[tokio::test]
+    async fn coalesces_and_converges() {
+        let fx = make_fixture().await;
+        let nar_url = nar_url_from(&fx.narinfo_text);
+        let (upstream_url, counter) =
+            spawn_upstream(fx.narinfo_text.clone(), nar_url, fx.nar_xz.clone(), false, 200).await;
+        let cfg = make_config(&fx, upstream_url);
+        let metrics = web::Data::new(crate::prometheus::initialize_metrics().unwrap());
+        let cache = Arc::new(NarInfoCache::new(16, std::time::Duration::from_secs(60)));
+        let registry = Arc::new(JobRegistry::new(cache));
+
+        // N concurrent attachers for the same missing path, launched together
+        // (no stagger) so they all coalesce onto one live job.
+        const N: usize = 8;
+        let mut handles = Vec::new();
+        for _ in 0..N {
+            let reg = registry.clone();
+            let cfg = cfg.clone();
+            let metrics = metrics.clone();
+            let hash = fx.store_path_hash.clone();
+            handles.push(tokio::spawn(async move {
+                match reg.attach(cfg, metrics, &hash).await {
+                    Attach::Live(body) => drain(body).await,
+                    Attach::Parked(_) => Err(std::io::Error::other("unexpected Parked")),
+                }
+            }));
+        }
+
+        let mut bodies = Vec::new();
+        for h in handles {
+            bodies.push(h.await.unwrap().expect("client body errored"));
+        }
+
+        // Every client body equals the golden decompressed NAR.
+        for (i, b) in bodies.iter().enumerate() {
+            assert_eq!(b, &fx.golden_nar, "client {i} body != golden NAR");
+        }
+
+        // Exactly one upstream nar.xz GET (coalescing).
+        assert_eq!(
+            counter.load(Ordering::SeqCst),
+            1,
+            "expected exactly one upstream nar.xz GET"
+        );
+
+        // Give the store import a moment to settle, then assert the path is
+        // valid in the destination store.
+        for _ in 0..100 {
+            if path_is_valid(&fx) {
+                break;
+            }
+            tokio::time::sleep(std::time::Duration::from_millis(50)).await;
+        }
+        assert!(path_is_valid(&fx), "path did not become valid after job");
+    }
