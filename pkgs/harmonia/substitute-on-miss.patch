diff --git a/harmonia-cache/src/upstream.rs b/harmonia-cache/src/upstream.rs
new file mode 100644
index 0000000..3a34006
--- /dev/null
+++ b/harmonia-cache/src/upstream.rs
@@ -0,0 +1,44 @@
+//! Upstream binary-cache HTTP client (reqwest, rustls). One-shot narinfo GET
+//! and a streaming NAR body reader for the stream-through cache.
+
+use std::sync::LazyLock;
+
+use futures_util::StreamExt as _;
+use tokio_util::io::StreamReader;
+
+static CLIENT: LazyLock<reqwest::Client> =
+    LazyLock::new(|| reqwest::Client::builder().build().expect("reqwest client"));
+
+fn url(upstream: &str, path: &str) -> String {
+    format!("{}/{}", upstream.trim_end_matches('/'), path.trim_start_matches('/'))
+}
+
+pub(crate) async fn get_text(upstream: &str, path: &str) -> Result<String, String> {
+    CLIENT
+        .get(url(upstream, path))
+        .send()
+        .await
+        .map_err(|e| format!("upstream GET: {e}"))?
+        .error_for_status()
+        .map_err(|e| format!("upstream status: {e}"))?
+        .text()
+        .await
+        .map_err(|e| format!("upstream body: {e}"))
+}
+
+pub(crate) async fn get_stream(
+    upstream: &str,
+    path: &str,
+) -> Result<impl tokio::io::AsyncBufRead + Unpin + Send, String> {
+    let resp = CLIENT
+        .get(url(upstream, path))
+        .send()
+        .await
+        .map_err(|e| format!("upstream GET: {e}"))?
+        .error_for_status()
+        .map_err(|e| format!("upstream status: {e}"))?;
+    let stream = resp
+        .bytes_stream()
+        .map(|r| r.map_err(std::io::Error::other));
+    Ok(StreamReader::new(stream))
+}
diff --git a/harmonia-cache/src/upstream_narinfo.rs b/harmonia-cache/src/upstream_narinfo.rs
new file mode 100644
index 0000000..68e5058
--- /dev/null
+++ b/harmonia-cache/src/upstream_narinfo.rs
@@ -0,0 +1,340 @@
+//! Parse an upstream (cache.nixos.org) narinfo and produce (a) the client-
+//! facing narinfo rewritten to point at harmonia's own NAR endpoint with
+//! Compression: none, and (b) a ValidPathInfo for add_to_store_nar. The
+//! rewrite only touches URL/Compression/FileHash/FileSize, which are NOT in
+//! the signature fingerprint (1;path;narhash;narsize;refs), so the upstream
+//! Sig lines stay valid.
+
+use std::collections::BTreeSet;
+
+use harmonia_protocol::nar_hash::NarHash;
+use harmonia_protocol::valid_path_info::{UnkeyedValidPathInfo, ValidPathInfo};
+use harmonia_store_core::signature::Signature;
+use harmonia_store_core::store_path::{ContentAddress, StoreDir, StorePath};
+use harmonia_utils_hash::Hash;
+use harmonia_utils_hash::fmt::{Any, CommonHash};
+
+pub(crate) struct UpstreamNarInfo {
+    pub store_path: String,      // "/nix/store/<hash>-<name>"
+    pub store_path_hash: String, // "<outhash>" (32 base32)
+    pub nar_hash_bare: String,   // NAR hash, bare base32 (no "sha256:")
+    pub nar_url: String,         // upstream "nar/<filehash>.nar.{xz,zst,...}"
+    pub upstream_compression: String, // how the upstream NAR is compressed
+    pub client_narinfo: String,  // rewritten text served to clients
+    pub info: ValidPathInfo,     // for add_to_store_nar
+}
+
+/// Infer the compression method from an upstream NAR URL's extension. Only used
+/// as a fallback when the narinfo omits the `Compression:` field (cache.nixos.org
+/// always sets it, but other substituters may not).
+fn infer_compression_from_url(url: &str) -> String {
+    if url.ends_with(".nar.zst") {
+        "zstd"
+    } else if url.ends_with(".nar.xz") {
+        "xz"
+    } else if url.ends_with(".nar.bz2") {
+        "bzip2"
+    } else if url.ends_with(".nar") {
+        "none"
+    } else {
+        // Unknown extension: assume xz, the historical cache.nixos.org default.
+        "xz"
+    }
+    .to_string()
+}
+
+pub(crate) fn parse_upstream_narinfo(
+    store_dir: &StoreDir,
+    text: &str,
+) -> Result<UpstreamNarInfo, String> {
+    let mut store_path = None;
+    let mut url = None;
+    let mut compression = None;
+    let mut nar_hash = None; // e.g. "sha256:<base32>" or "sha256-..." — keep as-is for parse
+    let mut nar_size = None;
+    let mut references: Vec<&str> = Vec::new();
+    let mut deriver = None;
+    let mut ca = None;
+    let mut sigs: Vec<&str> = Vec::new();
+
+    for line in text.lines() {
+        let Some((k, v)) = line.split_once(": ") else {
+            continue;
+        };
+        match k {
+            "StorePath" => store_path = Some(v.trim().to_string()),
+            "URL" => url = Some(v.trim().to_string()),
+            "Compression" => compression = Some(v.trim().to_string()),
+            "NarHash" => nar_hash = Some(v.trim().to_string()),
+            "NarSize" => nar_size = Some(v.trim().to_string()),
+            "References" => {
+                references = v.split_whitespace().collect();
+            }
+            "Deriver" => deriver = Some(v.trim().to_string()),
+            "CA" => ca = Some(v.trim().to_string()),
+            "Sig" => sigs.push(v.trim()),
+            _ => {}
+        }
+    }
+
+    let store_path = store_path.ok_or("upstream narinfo: no StorePath")?;
+    let url = url.ok_or("upstream narinfo: no URL")?;
+    let nar_hash_raw = nar_hash.ok_or("upstream narinfo: no NarHash")?;
+    let nar_size_str = nar_size.ok_or("upstream narinfo: no NarSize")?;
+    let nar_size: u64 = nar_size_str
+        .parse()
+        .map_err(|e| format!("bad NarSize: {e}"))?;
+
+    // Parse against the *configured* store dir — handles chroot stores, no
+    // hardcoded "/nix/store" — and take the canonical hash from the parsed
+    // path (`StorePath::hash()` has a base32 Display), so no fragile
+    // `split_once('-')` and no reliance on a dash being present.
+    let sp: StorePath = store_dir
+        .parse(&store_path)
+        .map_err(|e| format!("parse StorePath: {e}"))?;
+    let store_path_hash = sp.hash().to_string();
+
+    // NarHash may be "sha256:<base32>" or "sha256-<base64 SRI>"; harmonia's
+    // client nar route expects bare base32. Normalize to bare base32 for the
+    // rewritten URL. Reuse harmonia's Hash parser (Any<Hash>) to be exact.
+    let nar_hash_bare = normalize_nar_hash_bare(&nar_hash_raw)?;
+
+    // How the upstream NAR is compressed, so the job decodes it correctly.
+    // cache.nixos.org serves zstd today, xz historically; honor the field and
+    // fall back to the URL extension only if it is absent or empty.
+    let upstream_compression = match compression.as_deref().map(str::trim) {
+        Some(c) if !c.is_empty() => c.to_string(),
+        _ => infer_compression_from_url(&url),
+    };
+    let info = build_valid_path_info(
+        store_dir,
+        sp,
+        &nar_hash_raw,
+        nar_size,
+        &references,
+        deriver.as_deref(),
+        ca.as_deref(),
+        &sigs,
+    )?;
+
+    // Rewritten client narinfo: URL -> harmonia nix-serve nar route, no
+    // compression, FileHash/FileSize = NarHash/NarSize. Keep Sig lines.
+    let mut out = String::new();
+    out.push_str(&format!("StorePath: {store_path}\n"));
+    out.push_str(&format!(
+        "URL: nar/{store_path_hash}-{nar_hash_bare}.nar\n"
+    ));
+    out.push_str("Compression: none\n");
+    out.push_str(&format!("FileHash: {nar_hash_raw}\n"));
+    out.push_str(&format!("FileSize: {nar_size}\n"));
+    out.push_str(&format!("NarHash: {nar_hash_raw}\n"));
+    out.push_str(&format!("NarSize: {nar_size}\n"));
+    if !references.is_empty() {
+        out.push_str(&format!("References: {}\n", references.join(" ")));
+    }
+    if let Some(d) = &deriver {
+        out.push_str(&format!("Deriver: {d}\n"));
+    }
+    if let Some(c) = &ca {
+        out.push_str(&format!("CA: {c}\n"));
+    }
+    for s in &sigs {
+        out.push_str(&format!("Sig: {s}\n"));
+    }
+
+    Ok(UpstreamNarInfo {
+        store_path,
+        store_path_hash,
+        nar_hash_bare,
+        nar_url: url,
+        upstream_compression,
+        client_narinfo: out,
+        info,
+    })
+}
+
+/// Normalize a NarHash string (either "sha256:<base32>" or SRI "sha256-<base64>")
+/// to bare base32 (no prefix), as used in harmonia's NAR URL route.
+fn normalize_nar_hash_bare(raw: &str) -> Result<String, String> {
+    let h: Hash = raw
+        .parse::<Any<Hash>>()
+        .map_err(|e| e.to_string())?
+        .into_hash();
+    Ok(h.as_base32().as_bare().to_string())
+}
+
+/// Build a ValidPathInfo from parsed upstream narinfo fields.
+#[allow(clippy::too_many_arguments)]
+fn build_valid_path_info(
+    store_dir: &StoreDir,
+    sp: StorePath,
+    nar_hash_raw: &str,
+    nar_size: u64,
+    references: &[&str],
+    deriver: Option<&str>,
+    ca: Option<&str>,
+    sigs: &[&str],
+) -> Result<ValidPathInfo, String> {
+    // Parse NarHash (sha256:<base32> or SRI) into the protocol NarHash type.
+    let h: Hash = nar_hash_raw
+        .parse::<Any<Hash>>()
+        .map_err(|e| e.to_string())?
+        .into_hash();
+    let nar_hash = NarHash::try_from(h).map_err(|e| format!("NarHash type error: {e}"))?;
+
+    // Parse references: upstream narinfo encodes them as basename-only paths
+    // (e.g. "hash-name"), so we use StorePath::from_base_path directly.
+    let mut refs: BTreeSet<StorePath> = BTreeSet::new();
+    for r in references {
+        let rsp = StorePath::from_base_path(r)
+            .map_err(|e| format!("invalid reference '{r}': {e}"))?;
+        refs.insert(rsp);
+    }
+
+    // Parse optional deriver (also basename-only in upstream narinfo).
+    let deriver_sp: Option<StorePath> = deriver
+        .map(|d| {
+            StorePath::from_base_path(d).map_err(|e| format!("invalid deriver '{d}': {e}"))
+        })
+        .transpose()?;
+
+    // Parse optional content address.
+    let content_address: Option<ContentAddress> = ca
+        .map(|c| {
+            c.parse::<ContentAddress>()
+                .map_err(|e| format!("invalid CA '{c}': {e}"))
+        })
+        .transpose()?;
+
+    // Parse signatures.
+    let mut signatures: BTreeSet<Signature> = BTreeSet::new();
+    for s in sigs {
+        let sig: Signature = s
+            .parse::<Signature>()
+            .map_err(|e| format!("invalid Sig '{s}': {e}"))?;
+        signatures.insert(sig);
+    }
+
+    Ok(ValidPathInfo {
+        path: sp,
+        info: UnkeyedValidPathInfo {
+            deriver: deriver_sp,
+            nar_hash,
+            references: refs,
+            registration_time: None,
+            nar_size,
+            ultimate: false,
+            signatures,
+            ca: content_address,
+            store_dir: store_dir.clone(),
+        },
+    })
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    // A minimal valid store_dir for /nix/store.
+    fn sd() -> StoreDir {
+        StoreDir::default()
+    }
+
+    // Real-looking, correctly-sized hash values.
+    // Store path hash: 32 nix base32 chars (from the harmonia store_dir doctest).
+    // NarHash (sha256 base32): 52 nix base32 chars (sha256 of "abc" from fmt.rs tests).
+    // Signature: "cache.nixos.org-1:" + 88-char base64 of 64 zero bytes.
+    const STORE_HASH: &str = "55xkmqns51sw7nrgykp5vnz36w4fr3cw";
+    const NAR_HASH_B32: &str = "1b8m03r63zqhnjf7l5wnldhh7c134ap5vpj0850ymkq1iyzicy5s";
+    const SIG_B64: &str =
+        "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==";
+
+    fn sample() -> String {
+        format!(
+            "StorePath: /nix/store/{STORE_HASH}-nix-2.1.3\n\
+             URL: nar/1abc.nar.xz\n\
+             Compression: xz\n\
+             FileHash: sha256:{NAR_HASH_B32}\n\
+             FileSize: 10\n\
+             NarHash: sha256:{NAR_HASH_B32}\n\
+             NarSize: 20\n\
+             References: {STORE_HASH}-nix-2.1.3\n\
+             Sig: cache.nixos.org-1:{SIG_B64}\n"
+        )
+    }
+
+    #[test]
+    fn rewrite_points_at_harmonia_and_keeps_sig() {
+        let text = sample();
+        let up = parse_upstream_narinfo(&sd(), &text).unwrap();
+
+        // URL must be rewritten to harmonia's nar route
+        let expected_url = format!("URL: nar/{STORE_HASH}-{NAR_HASH_B32}.nar");
+        assert!(
+            up.client_narinfo.contains(&expected_url),
+            "client_narinfo missing expected URL; got:\n{}",
+            up.client_narinfo
+        );
+
+        // Compression must be none
+        assert!(
+            up.client_narinfo.contains("Compression: none"),
+            "client_narinfo missing 'Compression: none'; got:\n{}",
+            up.client_narinfo
+        );
+
+        // Sig line must be preserved verbatim
+        let expected_sig = format!("Sig: cache.nixos.org-1:{SIG_B64}");
+        assert!(
+            up.client_narinfo.contains(&expected_sig),
+            "client_narinfo missing expected Sig; got:\n{}",
+            up.client_narinfo
+        );
+
+        // NarSize fingerprint field must be unchanged
+        assert!(
+            up.client_narinfo.contains("NarSize: 20"),
+            "client_narinfo missing 'NarSize: 20'; got:\n{}",
+            up.client_narinfo
+        );
+
+        // nar_url must be the original upstream URL (not rewritten)
+        assert_eq!(up.nar_url, "nar/1abc.nar.xz");
+
+        // upstream compression must be captured from the Compression: field
+        assert_eq!(up.upstream_compression, "xz");
+
+        // store_path_hash must equal the hash from the parsed StorePath
+        assert_eq!(up.store_path_hash, STORE_HASH);
+
+        // nar_hash_bare must be bare base32 (no "sha256:" prefix)
+        assert_eq!(up.nar_hash_bare, NAR_HASH_B32);
+
+        // ValidPathInfo must have correct nar_size
+        assert_eq!(up.info.info.nar_size, 20);
+    }
+
+    #[test]
+    fn captures_zstd_compression() {
+        // cache.nixos.org serves zstd today: the field must be honored so the
+        // NAR job picks the zstd decoder rather than the hard-coded xz one.
+        let text = sample()
+            .replace("URL: nar/1abc.nar.xz", "URL: nar/1abc.nar.zst")
+            .replace("Compression: xz", "Compression: zstd");
+        let up = parse_upstream_narinfo(&sd(), &text).unwrap();
+        assert_eq!(up.upstream_compression, "zstd");
+        assert_eq!(up.nar_url, "nar/1abc.nar.zst");
+        // Client still gets Compression: none (harmonia serves the raw NAR).
+        assert!(up.client_narinfo.contains("Compression: none"));
+    }
+
+    #[test]
+    fn infers_compression_from_url_when_field_absent() {
+        // A narinfo without a Compression: line falls back to the URL extension.
+        let text = sample()
+            .replace("URL: nar/1abc.nar.xz", "URL: nar/1abc.nar.zst")
+            .replace("Compression: xz\n", "");
+        let up = parse_upstream_narinfo(&sd(), &text).unwrap();
+        assert_eq!(up.upstream_compression, "zstd");
+    }
+}
