diff --git a/harmonia-cache/src/nar_job.rs b/harmonia-cache/src/nar_job.rs
new file mode 100644
index 0000000..f63621c
--- /dev/null
+++ b/harmonia-cache/src/nar_job.rs
@@ -0,0 +1,1583 @@
+//! Per-path streaming NAR job + coalescing registry for substitute-on-miss.
+//!
+//! A `Job` fetches exactly one upstream `<filehash>.nar.<compression>`, decodes
+//! it per the upstream narinfo's `Compression` (zstd/xz/bzip2/none), and
+//! fans the decoded NAR bytes to (a) live client streams via a `broadcast` and
+//! (b) the local nix store via `add_to_store_nar` on the miss daemon socket.
+//!
+//! Concurrency contract (the load-bearing invariants):
+//!   * The store import is the durable priority. It runs to completion even if
+//!     every client disconnects; convergence never depends on a client staying
+//!     attached.
+//!   * The store sink and the broadcast fan-out run *concurrently*: decoded
+//!     chunks are written into a `tokio::io::duplex` whose read half is drained
+//!     by `add_to_store_nar` on a spawned task. If we wrote to the duplex
+//!     without a concurrent drain, the 64 KiB buffer would fill and the fan-out
+//!     would deadlock.
+//!   * Coalescing: the registry keys `Weak<Job>` by store-path hash. A second
+//!     concurrent request for the same path upgrades the existing `Weak` and
+//!     subscribes to the same broadcast — it never starts a second fetch.
+//!   * Subscribe-before-first-chunk: the broadcast channel is created
+//!     synchronously in `Job::spawn` (which returns after the narinfo fetch but
+//!     before any chunk). The whole same-hash cohort — the creator and every
+//!     coalescer awaiting the shared creation — resolves that creation and
+//!     subscribes while the fan-out task is still doing its daemon connect and
+//!     the upstream `.nar.xz` GET (a network round trip), i.e. before the first
+//!     decoded chunk is broadcast. They therefore join the start-of-job cohort
+//!     and never miss the head.
+//!   * Single-fetch (single-flight): the registry never holds a lock across the
+//!     upstream fetch. Instead each hash has a *creation-in-progress* entry — a
+//!     `Shared` future the first arrival installs and every same-hash arrival
+//!     awaits — so a herd for one missing path coalesces onto one fetch/one job,
+//!     while requests for *distinct* hashes create their jobs concurrently
+//!     (their narinfo RTTs run in parallel; a single hung upstream fetch can no
+//!     longer stall creation for unrelated paths).
+
+use std::collections::HashMap;
+use std::future::Future;
+use std::pin::Pin;
+use std::sync::{Arc, Weak};
+use std::task::{Context, Poll};
+
+use actix_web::web;
+use bytes::{Bytes, BytesMut};
+use harmonia_protocol::types::DaemonStore as _;
+use futures_core::Stream;
+use futures_util::FutureExt as _;
+use futures_util::future::Shared;
+use tokio::io::{AsyncReadExt as _, AsyncWriteExt as _, BufReader};
+use tokio::sync::{broadcast, watch};
+
+use crate::config::Config;
+use crate::narinfo_cache::NarInfoCache;
+use crate::prometheus::PrometheusMetrics;
+use crate::upstream;
+use crate::upstream_narinfo::{UpstreamNarInfo, parse_upstream_narinfo};
+
+/// Broadcast channel capacity (chunks). A slow client that lags past this many
+/// buffered chunks gets `Lagged` and is dropped — it never gates the job.
+const BROADCAST_CAP: usize = 256;
+
+/// Read-buffer target for each decoded-chunk read. Chunks are split off a
+/// reusable `BytesMut` so both the store sink and every broadcast subscriber
+/// share a single ref-counted allocation.
+const CHUNK_TARGET: usize = 64 * 1024;
+
+/// Terminal state of a job, observed by parked (mid-stream) waiters.
+#[derive(Clone, Copy, Debug, PartialEq, Eq)]
+pub(crate) enum JobState {
+    /// The fan-out + store import are still in progress.
+    Running,
+    /// The store import completed and the path is now valid locally.
+    Ok,
+    /// The job failed (resolver, upstream, decode, or daemon import).
+    Failed,
+}
+
+/// A single in-flight streaming NAR job. Created (and kept alive) by the
+/// registry via an `Arc<Job>`; the fan-out task holds no strong reference back,
+/// so the job's registry slot drops once all clients + the registry release it.
+/// The fan-out task itself owns everything it needs and runs to completion
+/// regardless.
+pub(crate) struct Job {
+    /// Store-path hash (32-char base32); the registry key.
+    #[allow(dead_code)]
+    hash: String,
+    /// Live subscribers attach here. `send` never blocks and tolerates zero
+    /// receivers.
+    tx: broadcast::Sender<Bytes>,
+    /// Terminal-state signal for parked waiters (mid-stream arrivals).
+    done: watch::Receiver<JobState>,
+    /// Decompressed NAR size, from the upstream narinfo. Used with actix
+    /// `SizedStream` so live clients get a correct `Content-Length`.
+    nar_size: u64,
+}
+
+impl Job {
+    /// Spawn a new job: fetch/resolve the upstream narinfo (needed for
+    /// `nar_size` and the compressed `nar_url`), create the broadcast + done
+    /// channels, then spawn the fan-out task. Returns the `Arc<Job>`.
+    ///
+    /// Clients (the creator and any same-hash coalescers) subscribe *after* this
+    /// returns but *before the first chunk is broadcast*: `run_fanout` does a
+    /// daemon connect and the upstream `.nar.xz` GET (a network round trip)
+    /// before the first decoded chunk reaches the broadcast, so the whole
+    /// same-hash cohort has resolved the shared creation and subscribed within
+    /// that window — they join the start-of-job cohort and never miss the head.
+    ///
+    /// Returns `Err` only if the upstream narinfo cannot be resolved (so the
+    /// caller can 404); once a Job exists, its fan-out runs to completion.
+    async fn spawn(
+        cfg: web::Data<Config>,
+        metrics: web::Data<Arc<PrometheusMetrics>>,
+        registry: Arc<JobRegistry>,
+        hash: String,
+    ) -> Result<Arc<Job>, String> {
+        // Resolve the upstream narinfo first (cache-or-fetch). We need it up
+        // front for `nar_size` and to know the compressed `nar_url`.
+        let up = get_or_fetch_upstream(&cfg, &registry.cache, &hash).await?;
+        let nar_size = up.info.info.nar_size;
+
+        let (tx, _rx0) = broadcast::channel::<Bytes>(BROADCAST_CAP);
+        let (done_tx, done_rx) = watch::channel(JobState::Running);
+
+        let job = Arc::new(Job {
+            hash: hash.clone(),
+            tx: tx.clone(),
+            done: done_rx,
+            nar_size,
+        });
+
+        // The fan-out task owns the `Arc<Job>` for the whole run. This is what
+        // keeps the registry's `Weak` upgradeable (so concurrent requests
+        // coalesce) AND it is the last thing holding a broadcast `Sender`:
+        // clients therefore see a clean `Closed` EOF exactly when the job ends,
+        // independent of whether any client stays attached. The producing
+        // sender lives in `tx`; when the task returns it drops both `tx` and the
+        // `Arc<Job>` (which holds the other sender), closing the channel.
+        tokio::spawn(fanout(cfg, metrics, registry, hash, job.clone(), up, tx, done_tx));
+
+        Ok(job)
+    }
+}
+
+/// Resolve the upstream narinfo for `hash`: LRU hit, else fetch `<hash>.narinfo`
+/// from upstream, parse+rewrite it, and cache it.
+async fn get_or_fetch_upstream(
+    cfg: &Config,
+    cache: &NarInfoCache,
+    hash: &str,
+) -> Result<Arc<UpstreamNarInfo>, String> {
+    if let Some(up) = cache.get(hash) {
+        return Ok(up);
+    }
+    let text = upstream::get_text(&cfg.miss_upstream_url, &format!("/{hash}.narinfo")).await?;
+    let up = parse_upstream_narinfo(cfg.store.store_dir(), &text)?;
+    // Use the hash extracted from the upstream narinfo (authoritative), keying on
+    // `store_path_hash` so a normalised base32 form is always used.
+    let key = up.store_path_hash.clone();
+    let up = Arc::new(up);
+    cache.insert(key, up.clone());
+    Ok(up)
+}
+
+/// The heart: fetch the compressed NAR, xz-decode it, and concurrently feed the
+/// store sink (gated, durable) and the broadcast (non-blocking, best-effort).
+#[allow(clippy::too_many_arguments)]
+async fn fanout(
+    cfg: web::Data<Config>,
+    metrics: web::Data<Arc<PrometheusMetrics>>,
+    registry: Arc<JobRegistry>,
+    hash: String,
+    job: Arc<Job>,
+    up: Arc<UpstreamNarInfo>,
+    tx: broadcast::Sender<Bytes>,
+    done_tx: watch::Sender<JobState>,
+) {
+    metrics.nar_jobs_started_total.inc();
+
+    let result = run_fanout(&cfg, &up, &tx).await;
+
+    // Publish the terminal state to parked waiters, then evict our registry +
+    // narinfo-cache slots so the next request re-resolves cleanly.
+    let state = match &result {
+        Ok(()) => {
+            metrics.nar_jobs_completed_total.inc();
+            JobState::Ok
+        }
+        Err(e) => {
+            tracing::warn!(
+                "nar job {} ({}) failed: {e}",
+                up.store_path,
+                up.nar_hash_bare,
+            );
+            metrics.nar_jobs_failed_total.inc();
+            JobState::Failed
+        }
+    };
+    let _ = done_tx.send(state);
+    registry.remove(&hash);
+    registry.cache.remove(&hash);
+
+    // Dropping our producing `tx` and the `Arc<Job>` (which holds the other
+    // sender) closes the broadcast: still-attached clients see a clean EOF
+    // (`Closed` -> stream `None`). Held to the very end so watchers observe the
+    // final `done` value and so the registry `Weak` stays upgradeable (coalesce)
+    // for the whole run.
+    drop(tx);
+    drop(job);
+    drop(done_tx);
+}
+
+/// Inner fan-out that can `?`-propagate errors. On success the daemon has
+/// imported and validated the full NAR (nar-hash + trusted-keys enforced).
+async fn run_fanout(
+    cfg: &Config,
+    up: &UpstreamNarInfo,
+    tx: &broadcast::Sender<Bytes>,
+) -> Result<(), String> {
+    // Open the daemon that actually holds the store. Pin the client's store dir
+    // to our configured store so the ValidPathInfo's StorePath serializes with
+    // the right prefix (the daemon rejects paths outside its store dir).
+    let mut client = harmonia_store_remote::DaemonClientBuilder::new()
+        .set_store_dir(cfg.store.store_dir())
+        .connect_unix(&cfg.miss_daemon_socket)
+        .await
+        .map_err(|e| format!("daemon connect: {e}"))?;
+
+    // The store sink: decoded NAR bytes are written into `store_w`; the daemon
+    // drains `store_r`. These MUST run concurrently or the duplex buffer fills.
+    let (store_w, store_r) = tokio::io::duplex(CHUNK_TARGET);
+    let mut store_w = store_w;
+
+    let info = up.info.clone();
+    let import = async move {
+        client
+            .add_to_store_nar(&info, BufReader::new(store_r), false, false)
+            .await
+            .map_err(|e| format!("add_to_store_nar: {e}"))
+    };
+
+    // The producer: fetch + xz-decode, writing every byte to the store sink
+    // (the gate) and broadcasting each chunk (best-effort).
+    let produce = async move {
+        let nar_path = format!("/{}", up.nar_url);
+        let body = upstream::get_stream(&cfg.miss_upstream_url, &nar_path)
+            .await
+            .map_err(|e| format!("upstream nar GET: {e}"))?;
+        // Decode per the UPSTREAM narinfo's Compression. cache.nixos.org serves
+        // zstd today and xz historically; a hard-coded xz decoder fails
+        // "stream/file format not recognized" on a .nar.zst. Box the decoder so
+        // every method yields one `AsyncRead` the loop below can drive.
+        use async_compression::tokio::bufread;
+        let mut dec: Box<dyn tokio::io::AsyncRead + Unpin + Send> =
+            match up.upstream_compression.as_str() {
+                "none" => Box::new(body),
+                "xz" => Box::new(bufread::XzDecoder::new(body)),
+                "zstd" => Box::new(bufread::ZstdDecoder::new(body)),
+                "bzip2" => Box::new(bufread::BzDecoder::new(body)),
+                other => {
+                    return Err(format!("unsupported upstream compression: {other:?}"));
+                }
+            };
+
+        let mut buf = BytesMut::with_capacity(CHUNK_TARGET);
+        loop {
+            buf.reserve(CHUNK_TARGET);
+            let n = dec
+                .read_buf(&mut buf)
+                .await
+                .map_err(|e| format!("nar decode: {e}"))?;
+            if n == 0 {
+                break;
+            }
+            let chunk = buf.split().freeze();
+            // The gate: every byte must reach the store sink. If the daemon
+            // hangs up (import failed), this errors and we stop.
+            store_w
+                .write_all(&chunk)
+                .await
+                .map_err(|e| format!("store sink write: {e}"))?;
+            // Best-effort broadcast; zero receivers is fine.
+            let _ = tx.send(chunk);
+        }
+        store_w
+            .shutdown()
+            .await
+            .map_err(|e| format!("store sink shutdown: {e}"))?;
+        Ok::<(), String>(())
+    };
+
+    // Drive both concurrently. The import future is the durable half; the
+    // producer feeds it. A producer error (e.g. truncated upstream) surfaces as
+    // an incomplete NAR, which the daemon rejects — so `import` also errors and
+    // the path is not made valid.
+    let (produce_res, import_res) = tokio::join!(produce, import);
+    produce_res?;
+    import_res?;
+    Ok(())
+}
+
+/// How a client attaches to a path's job.
+pub(crate) enum Attach {
+    /// A live broadcast stream: the client joined the start-of-job cohort and
+    /// receives the whole NAR from the head.
+    Live(BroadcastBody),
+    /// A mid-stream arrival: await the job's terminal state, then serve from the
+    /// store (on `Ok`) or 404 (on `Failed`).
+    Parked(watch::Receiver<JobState>),
+}
+
+/// The boxed creation future's output: the created job, or an `Arc`-wrapped
+/// error message (`Arc` so `Shared`'s `Clone`-output requirement is met and
+/// every same-hash waiter can observe the same failure).
+type CreationOutput = Result<Arc<Job>, Arc<String>>;
+
+/// The boxed, type-erased creation future before it is made shareable.
+type BoxCreationFut = Pin<Box<dyn Future<Output = CreationOutput> + Send>>;
+
+/// A shared, cloneable future resolving to the created job. The future performs
+/// the upstream narinfo fetch + `Job::spawn` **off the registry lock**; every
+/// same-hash arrival awaits this one `Shared` (single-flight).
+type CreationFut = Shared<BoxCreationFut>;
+
+/// A registry slot, keyed by store-path hash.
+enum CreationState {
+    /// A creation is in flight: the first arrival installed this future and
+    /// every same-hash arrival awaits *this same* `Shared` (single-flight), so
+    /// they coalesce onto one narinfo fetch and one `Job`.
+    InProgress(CreationFut),
+    /// A completed-but-still-live job. Kept as a `Weak` so the job's slot drops
+    /// once all clients + the fan-out task release it.
+    Live(Weak<Job>),
+}
+
+/// Coalescing registry of in-flight NAR jobs, keyed by store-path hash.
+///
+/// The map is guarded by a plain (non-async) mutex held only for brief
+/// insert/lookup — **never across the upstream fetch**. Single-fetch is instead
+/// guaranteed by a per-hash single-flight future ([`CreationState::InProgress`]):
+/// a herd for one missing path all awaits one `Shared` creation, while distinct
+/// hashes create concurrently. Creation (one narinfo RTT + a task spawn) runs
+/// off the lock; the actual NAR streaming happens in the fan-out task.
+pub(crate) struct JobRegistry {
+    jobs: std::sync::Mutex<HashMap<String, CreationState>>,
+    cache: Arc<NarInfoCache>,
+}
+
+impl JobRegistry {
+    pub(crate) fn new(cache: Arc<NarInfoCache>) -> Self {
+        Self {
+            jobs: std::sync::Mutex::new(HashMap::new()),
+            cache,
+        }
+    }
+
+    /// Evict a job's slot once its fan-out ends. Only removes a `Live` slot: a
+    /// slot may already have been replaced by a *new* in-progress creation
+    /// (after this job finished and its narinfo-cache entry was dropped), and we
+    /// must not clobber that.
+    fn remove(&self, hash: &str) {
+        let mut jobs = self.jobs.lock().unwrap();
+        if matches!(jobs.get(hash), Some(CreationState::Live(_))) {
+            jobs.remove(hash);
+        }
+    }
+
+    /// Join or create the job for `store_path_hash`.
+    ///
+    /// Fast path (caller's responsibility): the caller checks the local store
+    /// first and only calls `attach` on a genuine miss.
+    ///
+    /// * An existing job still `Running` → `Live` (subscribe to its broadcast).
+    /// * An existing job finishing/finished → `Parked` (await, then store-serve).
+    /// * A creation already in flight for this hash → await it (coalesce), then
+    ///   subscribe — no second fetch.
+    /// * No job and no creation → install a single-flight creation future, drop
+    ///   the lock, drive it (fetch + `Job::spawn`) off the lock, then subscribe.
+    ///   If the upstream narinfo can't be resolved, we surface a miss by
+    ///   returning `Parked` on a channel already set to `Failed`.
+    pub(crate) async fn attach(
+        self: &Arc<Self>,
+        cfg: web::Data<Config>,
+        metrics: web::Data<Arc<PrometheusMetrics>>,
+        store_path_hash: &str,
+    ) -> Attach {
+        // Decide, under the brief map lock, whether we join an existing job,
+        // await an in-flight creation, or become the creator. The lock is never
+        // held across an await.
+        enum Plan {
+            /// Subscribe to this already-live, still-running job.
+            Live(Arc<Job>),
+            /// This job is finishing/finished; park on its terminal state.
+            Parked(watch::Receiver<JobState>),
+            /// Await this in-flight creation (coalesced onto an existing fetch),
+            /// then subscribe to the resulting job.
+            Await(CreationFut),
+            /// We are the creator: drive this future, publish the result.
+            Create(CreationFut),
+        }
+
+        let plan = {
+            let mut jobs = self.jobs.lock().unwrap();
+            match jobs.get(store_path_hash) {
+                Some(CreationState::Live(weak)) => match weak.upgrade() {
+                    Some(job) if *job.done.borrow() == JobState::Running => Plan::Live(job),
+                    Some(job) => Plan::Parked(job.done.clone()),
+                    // Dead `Weak` (fan-out ended, slot not yet reaped, or a lost
+                    // remove race): treat as no job and create fresh.
+                    None => {
+                        let fut = self.make_creation_fut(&cfg, &metrics, store_path_hash);
+                        jobs.insert(store_path_hash.to_string(), CreationState::InProgress(fut.clone()));
+                        Plan::Create(fut)
+                    }
+                },
+                Some(CreationState::InProgress(fut)) => Plan::Await(fut.clone()),
+                None => {
+                    let fut = self.make_creation_fut(&cfg, &metrics, store_path_hash);
+                    jobs.insert(store_path_hash.to_string(), CreationState::InProgress(fut.clone()));
+                    Plan::Create(fut)
+                }
+            }
+        };
+
+        match plan {
+            Plan::Live(job) => {
+                let rx = job.tx.subscribe();
+                metrics.nar_clients_attached_total.inc();
+                Attach::Live(BroadcastBody::new(
+                    rx,
+                    job.nar_size,
+                    job.done.clone(),
+                    Arc::clone(&*metrics),
+                ))
+            }
+            Plan::Parked(done) => Attach::Parked(done),
+            // Creator and coalesced waiter are now symmetric: both only *await*
+            // and *observe* the shared creation. The slot finalization (swap to
+            // `Live` on success / remove on failure) lives INSIDE the creation
+            // future itself (see `make_creation_fut`), so it runs whenever the
+            // creation resolves — driven by whichever task polls the `Shared` to
+            // completion — and never depends on the first caller's request future
+            // surviving. If the creator's request future is dropped mid-creation,
+            // a coalesced waiter still drives the `Shared`, and the finalizer
+            // still runs.
+            Plan::Await(fut) | Plan::Create(fut) => match fut.await {
+                Ok(job) => self.subscribe_after_await(&metrics, job),
+                Err(_) => {
+                    // The creation logged the failure and already removed the
+                    // slot via its finalizer; treat as a miss.
+                    let (_tx, rx) = watch::channel(JobState::Failed);
+                    Attach::Parked(rx)
+                }
+            },
+        }
+    }
+
+    /// Build the single-flight creation future for `hash`: fetch the upstream
+    /// narinfo and `Job::spawn` (which spawns the fan-out task), then FINALIZE
+    /// this hash's registry slot from within the future itself. Runs entirely
+    /// off the registry lock.
+    ///
+    /// Finalization is owned by the creation future, not by any caller's request
+    /// future: on the creation resolving, the slot is swapped `InProgress ->
+    /// Live(Weak<Job>)` (success) or removed (failure) exactly once. Because the
+    /// underlying `BoxCreationFut` runs a single time — driven by whichever task
+    /// polls the `Shared` to completion — this holds even when the original
+    /// creator's request future is dropped mid-creation: a coalesced waiter
+    /// keeps driving the `Shared`, so the finalizer still runs. This closes the
+    /// creator-cancellation wedge where the slot was left `InProgress(completed)`
+    /// forever.
+    fn make_creation_fut(
+        self: &Arc<Self>,
+        cfg: &web::Data<Config>,
+        metrics: &web::Data<Arc<PrometheusMetrics>>,
+        hash: &str,
+    ) -> CreationFut {
+        let registry = self.clone();
+        let cfg = cfg.clone();
+        let metrics = metrics.clone();
+        let hash = hash.to_string();
+        let fut: BoxCreationFut = Box::pin(async move {
+            let result = Job::spawn(cfg, metrics, registry.clone(), hash.clone())
+                .await
+                .map_err(Arc::new);
+            // Finalize this hash's slot from within the creation future so it is
+            // independent of which task drove (or dropped) the creation. Under
+            // the brief map lock (never held across an await), and only if the
+            // slot is still our in-progress creation — a later fan-out finish may
+            // already have reaped/replaced it, and a subsequent creation may have
+            // taken the slot; we must not clobber either.
+            {
+                let mut jobs = registry.jobs.lock().unwrap();
+                if matches!(jobs.get(&hash), Some(CreationState::InProgress(_))) {
+                    match &result {
+                        Ok(job) => {
+                            jobs.insert(hash.clone(), CreationState::Live(Arc::downgrade(job)));
+                        }
+                        Err(e) => {
+                            tracing::warn!("nar job resolve for {hash} failed: {e}");
+                            jobs.remove(&hash);
+                        }
+                    }
+                }
+            }
+            result
+        });
+        fut.shared()
+    }
+
+    /// Subscribe an attaching client to `job` after awaiting its (possibly
+    /// shared) creation. A still-`Running` job yields a `Live` body from a fresh
+    /// broadcast subscription (a late arrival may miss the head but the store
+    /// import is durable); a finished/failed job yields `Parked`.
+    fn subscribe_after_await(
+        &self,
+        metrics: &web::Data<Arc<PrometheusMetrics>>,
+        job: Arc<Job>,
+    ) -> Attach {
+        if *job.done.borrow() == JobState::Running {
+            let rx = job.tx.subscribe();
+            metrics.nar_clients_attached_total.inc();
+            Attach::Live(BroadcastBody::new(
+                rx,
+                job.nar_size,
+                job.done.clone(),
+                Arc::clone(&**metrics),
+            ))
+        } else {
+            Attach::Parked(job.done.clone())
+        }
+    }
+}
+
+/// The future type driven by `BroadcastBody`: it owns the receiver (moved in)
+/// and returns it back alongside the recv result, so there is exactly one
+/// receiver and no self-reference.
+type RecvFut = Pin<
+    Box<
+        dyn Future<
+                Output = (
+                    broadcast::Receiver<Bytes>,
+                    Result<Bytes, broadcast::error::RecvError>,
+                ),
+            > + Send,
+    >,
+>;
+
+/// A `Stream` of `Result<Bytes, io::Error>` over a broadcast receiver, for use
+/// with actix `SizedStream`. `Lagged` ends the client with an error; a clean
+/// `Closed` after a **successful** job is EOF; a `Closed` after a **failed**
+/// job (e.g. truncated upstream, daemon reject) yields an error so the client
+/// never mistakes a partial NAR for a complete one.
+///
+/// The receiver is the single source of truth. When idle it lives in `rx`; when
+/// awaiting the next message it is moved into `fut` and handed back on
+/// completion — so there is never a second receiver advancing independently.
+pub(crate) struct BroadcastBody {
+    rx: Option<broadcast::Receiver<Bytes>>,
+    fut: Option<RecvFut>,
+    nar_size: u64,
+    /// Terminal-state signal, checked on `Closed` to distinguish a completed
+    /// job (clean EOF) from a failed one (error out the client).
+    done: watch::Receiver<JobState>,
+    /// Metrics handle used to increment `nar_clients_dropped_total` on `Lagged`.
+    metrics: Arc<PrometheusMetrics>,
+}
+
+impl BroadcastBody {
+    pub(crate) fn new(
+        rx: broadcast::Receiver<Bytes>,
+        nar_size: u64,
+        done: watch::Receiver<JobState>,
+        metrics: Arc<PrometheusMetrics>,
+    ) -> Self {
+        Self {
+            rx: Some(rx),
+            fut: None,
+            nar_size,
+            done,
+            metrics,
+        }
+    }
+
+    pub(crate) fn nar_size(&self) -> u64 {
+        self.nar_size
+    }
+}
+
+impl Stream for BroadcastBody {
+    type Item = Result<Bytes, std::io::Error>;
+
+    fn poll_next(self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Option<Self::Item>> {
+        let this = self.get_mut();
+
+        // Arm the recv future if idle, moving the sole receiver into it.
+        if this.fut.is_none() {
+            let mut rx = this.rx.take().expect("receiver present when idle");
+            this.fut = Some(Box::pin(async move {
+                let res = rx.recv().await;
+                (rx, res)
+            }));
+        }
+
+        let fut = this.fut.as_mut().unwrap();
+        match fut.as_mut().poll(cx) {
+            Poll::Ready((rx, res)) => {
+                // Return the receiver to its idle slot for the next poll.
+                this.fut = None;
+                this.rx = Some(rx);
+                match res {
+                    Ok(bytes) => Poll::Ready(Some(Ok(bytes))),
+                    Err(broadcast::error::RecvError::Closed) => {
+                        // The channel closed because the fan-out task ended and
+                        // dropped its senders. Distinguish success (clean EOF)
+                        // from failure (error the client so a partial NAR is not
+                        // mistaken for a complete one).
+                        if *this.done.borrow() == JobState::Failed {
+                            Poll::Ready(Some(Err(std::io::Error::other("nar job failed"))))
+                        } else {
+                            Poll::Ready(None)
+                        }
+                    }
+                    Err(broadcast::error::RecvError::Lagged(_)) => {
+                        this.metrics.nar_clients_dropped_total.inc();
+                        Poll::Ready(Some(Err(std::io::Error::other("lagged"))))
+                    }
+                }
+            }
+            Poll::Pending => Poll::Pending,
+        }
+    }
+}
