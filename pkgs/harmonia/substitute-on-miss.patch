+    async fn drain(mut body: BroadcastBody) -> Result<Vec<u8>, std::io::Error> {
+        let mut out = Vec::new();
+        while let Some(item) = body.next().await {
+            out.extend_from_slice(&item?);
+        }
+        Ok(out)
+    }
