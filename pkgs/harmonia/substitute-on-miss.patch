+    fn path_is_valid(fx: &Fixture) -> bool {
+        let store_path = format!(
+            "{}/{}",
+            fx.store_dir.display(),
+            // reconstruct <hash>-<name> from the store dir listing
+            std::fs::read_dir(&fx.store_dir)
+                .ok()
+                .and_then(|mut d| d
+                    .find_map(|e| {
+                        let e = e.ok()?;
+                        let n = e.file_name().to_string_lossy().to_string();
+                        n.starts_with(&fx.store_path_hash).then_some(n)
+                    }))
+                .unwrap_or_default()
+        );
+        // If nothing matched, the path can't be valid.
+        if store_path.ends_with('/') {
+            // Fall back to a daemon query by hash via nix-store on the socket.
+        }
+        let env = nix_env(fx.conf_dir.parent().unwrap());
+        let mut cmd = Command::new("nix-store");
+        cmd.args(["-q", "--hash", &store_path]);
+        cmd.env("NIX_REMOTE", format!("unix://{}", fx.socket.display()));
+        for (k, v) in &env {
+            if k != "NIX_REMOTE" {
+                cmd.env(k, v);
+            }
+        }
+        cmd.output().map(|o| o.status.success()).unwrap_or(false)
+    }
