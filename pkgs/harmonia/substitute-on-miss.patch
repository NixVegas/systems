+// Streaming NAR job — integration coverage.
+//
+// NOTE ON TEST LOCATION
+// ---------------------
+// The load-bearing streaming-job tests (coalescing under N concurrent
+// requests, store-import convergence, lead-client disconnect, and truncated
+// upstream rejection) live *inside the crate* in `src/nar_job.rs` under
+// `#[cfg(test)] mod tests`, and run with `cargo test --bins`. They must live
+// there because they drive `JobRegistry::attach` directly, and `attach` /
+// `Attach` / `BroadcastBody` are `pub(crate)` — an out-of-crate integration
+// test in this file cannot name them. Until the nar HTTP route that calls
+// `attach` is wired up (a later task), there is no public surface to drive the
+// job end-to-end over HTTP from here.
+//
+// This file exercises the *test harness contract* the in-crate tests depend on:
+// a minimal HTTP/1.1 fake upstream serving an xz body, decoded via the same
+// `async_compression` xz decoder the job uses. If this round-trip ever breaks
+// (e.g. an async-compression bump changes behaviour), this test fails loudly
+// and independently of the daemon-backed in-crate tests.
+
+use std::sync::Arc;
+use std::sync::atomic::{AtomicUsize, Ordering};
+
+use tokio::io::{AsyncReadExt, AsyncWriteExt};
+use tokio::net::TcpListener;
+
+/// Spawn a minimal HTTP/1.1 server that serves `xz` at `/blob.xz`, counting GETs.
+async fn spawn_upstream(xz: Vec<u8>) -> (String, Arc<AtomicUsize>) {
+    let listener = TcpListener::bind("127.0.0.1:0").await.unwrap();
+    let addr = listener.local_addr().unwrap();
+    let counter = Arc::new(AtomicUsize::new(0));
+    let counter_task = counter.clone();
+
+    tokio::spawn(async move {
+        loop {
+            let (mut sock, _) = match listener.accept().await {
+                Ok(s) => s,
+                Err(_) => break,
+            };
+            let xz = xz.clone();
+            let counter = counter_task.clone();
+            tokio::spawn(async move {
+                let mut buf = vec![0u8; 4096];
+                let n = match sock.read(&mut buf).await {
+                    Ok(0) | Err(_) => return,
+                    Ok(n) => n,
+                };
+                let _ = String::from_utf8_lossy(&buf[..n]);
+                counter.fetch_add(1, Ordering::SeqCst);
+                let head = format!(
+                    "HTTP/1.1 200 OK\r\nContent-Length: {}\r\nConnection: close\r\n\r\n",
+                    xz.len()
+                );
+                let _ = sock.write_all(head.as_bytes()).await;
+                let _ = sock.write_all(&xz).await;
+                let _ = sock.flush().await;
+            });
+        }
+    });
+
+    (format!("http://{addr}"), counter)
+}
+
+/// xz-compress `data` with the `xz` CLI (present in the dev shell).
+fn xz_compress(data: &[u8]) -> Vec<u8> {
+    use std::io::Write;
+    use std::process::{Command, Stdio};
+    let mut child = Command::new("xz")
+        .args(["-c", "-9"])
+        .stdin(Stdio::piped())
+        .stdout(Stdio::piped())
+        .spawn()
+        .expect("spawn xz");
+    child.stdin.take().unwrap().write_all(data).unwrap();
+    let out = child.wait_with_output().unwrap();
+    assert!(out.status.success(), "xz failed");
+    out.stdout
+}
+
+#[tokio::test]
+async fn fake_upstream_xz_roundtrip() {
+    let plain = b"the quick brown fox jumps over the lazy dog\n".repeat(1000);
+    let xz = xz_compress(&plain);
+    assert!(xz.len() < plain.len(), "xz should compress this payload");
+
+    let (url, counter) = spawn_upstream(xz).await;
+
+    // Fetch over HTTP with reqwest (the same client family the job uses) and
+    // decode via the same async-compression xz decoder the job uses.
+    let resp = reqwest::get(format!("{url}/blob.xz")).await.unwrap();
+    let body = resp.bytes().await.unwrap();
+    assert_eq!(counter.load(Ordering::SeqCst), 1, "exactly one GET");
+
+    let mut dec = async_compression::tokio::bufread::XzDecoder::new(
+        tokio::io::BufReader::new(std::io::Cursor::new(body.to_vec())),
+    );
+    let mut decoded = Vec::new();
+    tokio::io::AsyncReadExt::read_to_end(&mut dec, &mut decoded)
+        .await
+        .unwrap();
+
+    assert_eq!(decoded, plain, "xz round-trip through fake upstream");
+}
