+    /// A minimal HTTP/1.1 fake upstream. Serves `<hash>.narinfo` and the nar.xz;
+    /// counts nar.xz GETs; can optionally truncate the nar body to simulate a
+    /// broken upstream. Returns the bound base URL and the GET counter.
+    async fn spawn_upstream(
+        narinfo_text: String,
+        nar_url: String,
+        nar_xz: Vec<u8>,
+        truncate: bool,
+        nar_delay_ms: u64,
+    ) -> (String, Arc<AtomicUsize>) {
+        let listener = TcpListener::bind("127.0.0.1:0").await.unwrap();
+        let addr = listener.local_addr().unwrap();
+        let counter = Arc::new(AtomicUsize::new(0));
+        let counter_task = counter.clone();
+        let nar_suffix = nar_url.trim_start_matches('/').to_string();
+
+        tokio::spawn(async move {
+            loop {
+                let (mut sock, _) = match listener.accept().await {
+                    Ok(s) => s,
+                    Err(_) => break,
+                };
+                let narinfo_text = narinfo_text.clone();
+                let nar_xz = nar_xz.clone();
+                let nar_suffix = nar_suffix.clone();
+                let counter = counter_task.clone();
+                tokio::spawn(async move {
+                    let mut buf = vec![0u8; 4096];
+                    let n = match sock.read(&mut buf).await {
+                        Ok(0) | Err(_) => return,
+                        Ok(n) => n,
+                    };
+                    let req = String::from_utf8_lossy(&buf[..n]);
+                    let path = req
+                        .lines()
+                        .next()
+                        .and_then(|l| l.split_whitespace().nth(1))
+                        .unwrap_or("/")
+                        .to_string();
+
+                    if path.ends_with(".narinfo") {
+                        let body = narinfo_text.as_bytes();
+                        let head = format!(
+                            "HTTP/1.1 200 OK\r\nContent-Length: {}\r\nContent-Type: text/x-nix-narinfo\r\nConnection: close\r\n\r\n",
+                            body.len()
+                        );
+                        let _ = sock.write_all(head.as_bytes()).await;
+                        let _ = sock.write_all(body).await;
+                    } else if path.trim_start_matches('/').ends_with(&nar_suffix)
+                        || path.ends_with(".nar.xz")
+                    {
+                        counter.fetch_add(1, Ordering::SeqCst);
+                        // Hold the response briefly so all concurrent attachers
+                        // coalesce onto this one live job before it completes.
+                        if nar_delay_ms > 0 {
+                            tokio::time::sleep(std::time::Duration::from_millis(nar_delay_ms))
+                                .await;
+                        }
+                        if truncate {
+                            // Advertise the full length but send only a prefix,
+                            // then hang up: the client sees a short/broken body.
+                            let head = format!(
+                                "HTTP/1.1 200 OK\r\nContent-Length: {}\r\nContent-Type: application/x-xz\r\nConnection: close\r\n\r\n",
+                                nar_xz.len()
+                            );
+                            let _ = sock.write_all(head.as_bytes()).await;
+                            let cut = nar_xz.len() / 2;
+                            let _ = sock.write_all(&nar_xz[..cut]).await;
+                            // Drop the socket to force a premature EOF.
+                        } else {
+                            let head = format!(
+                                "HTTP/1.1 200 OK\r\nContent-Length: {}\r\nContent-Type: application/x-xz\r\nConnection: close\r\n\r\n",
+                                nar_xz.len()
+                            );
+                            let _ = sock.write_all(head.as_bytes()).await;
+                            let _ = sock.write_all(&nar_xz).await;
+                        }
+                    } else {
+                        let _ = sock
+                            .write_all(b"HTTP/1.1 404 Not Found\r\nContent-Length: 0\r\nConnection: close\r\n\r\n")
+                            .await;
+                    }
+                    let _ = sock.flush().await;
+                });
+            }
+        });
+
+        (format!("http://{addr}"), counter)
+    }
+
+    fn make_config(fx: &Fixture, upstream_url: String) -> web::Data<Config> {
+        let mut cfg: Config = toml::from_str("").unwrap();
+        cfg.substitute_on_miss = true;
+        cfg.miss_upstream_url = upstream_url;
+        cfg.miss_daemon_socket = fx.socket.clone();
+        cfg.store = crate::store::Store::new(
+            fx.store_dir.as_os_str().as_encoded_bytes().to_vec(),
+            None,
+            fx.state_dir.join("db/db.sqlite"),
+        );
+        web::Data::new(cfg)
