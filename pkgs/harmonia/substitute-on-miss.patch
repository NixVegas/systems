+            let mut cmd = Command::new("nix-store");
+            cmd.args(["--delete", &store_path]);
+            cmd.env("NIX_REMOTE", format!("unix://{}", fx.socket.display()));
+            for (k, v) in &env {
+                if k != "NIX_REMOTE" {
+                    cmd.env(k, v);
+                }
+            }
+            let _ = cmd.output();
+        }
+    }
