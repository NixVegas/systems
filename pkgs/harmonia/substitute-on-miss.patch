+    /// Tracks concurrent narinfo handlers across one or more fake upstreams:
+    /// `cur` is the number in flight right now, `max` the high-water mark.
+    #[derive(Clone, Default)]
+    struct NarinfoGauge {
+        cur: Arc<AtomicUsize>,
+        max: Arc<AtomicUsize>,
+    }
+    impl NarinfoGauge {
+        fn enter(&self) {
+            let now = self.cur.fetch_add(1, Ordering::SeqCst) + 1;
+            self.max.fetch_max(now, Ordering::SeqCst);
+        }
+        fn leave(&self) {
+            self.cur.fetch_sub(1, Ordering::SeqCst);
+        }
+        fn max(&self) -> usize {
+            self.max.load(Ordering::SeqCst)
+        }
+    }
+
+    /// Like [`spawn_upstream`] but the `.narinfo` handler holds a shared
+    /// concurrency gauge for `narinfo_delay_ms` before replying, so a test can
+    /// observe whether two distinct-hash narinfo fetches *overlapped*. The
+    /// nar.xz path is served immediately (no delay, no truncation).
+    async fn spawn_upstream_narinfo_gated(
+        narinfo_text: String,
+        nar_url: String,
+        nar_xz: Vec<u8>,
+        gauge: NarinfoGauge,
+        narinfo_delay_ms: u64,
+    ) -> String {
+        let listener = TcpListener::bind("127.0.0.1:0").await.unwrap();
+        let addr = listener.local_addr().unwrap();
+        let nar_suffix = nar_url.trim_start_matches('/').to_string();
+
+        tokio::spawn(async move {
+            loop {
+                let (mut sock, _) = match listener.accept().await {
+                    Ok(s) => s,
+                    Err(_) => break,
+                };
+                let narinfo_text = narinfo_text.clone();
+                let nar_xz = nar_xz.clone();
+                let nar_suffix = nar_suffix.clone();
+                let gauge = gauge.clone();
+                tokio::spawn(async move {
+                    let mut buf = vec![0u8; 4096];
+                    let n = match sock.read(&mut buf).await {
+                        Ok(0) | Err(_) => return,
+                        Ok(n) => n,
+                    };
+                    let req = String::from_utf8_lossy(&buf[..n]);
+                    let path = req
+                        .lines()
+                        .next()
+                        .and_then(|l| l.split_whitespace().nth(1))
+                        .unwrap_or("/")
+                        .to_string();
+
+                    if path.ends_with(".narinfo") {
+                        // Record overlap: hold the gauge across the delay so two
+                        // concurrent distinct-hash creations register max >= 2.
+                        gauge.enter();
+                        if narinfo_delay_ms > 0 {
+                            tokio::time::sleep(std::time::Duration::from_millis(narinfo_delay_ms))
+                                .await;
+                        }
+                        gauge.leave();
+                        let body = narinfo_text.as_bytes();
+                        let head = format!(
+                            "HTTP/1.1 200 OK\r\nContent-Length: {}\r\nContent-Type: text/x-nix-narinfo\r\nConnection: close\r\n\r\n",
+                            body.len()
+                        );
+                        let _ = sock.write_all(head.as_bytes()).await;
+                        let _ = sock.write_all(body).await;
+                    } else if path.trim_start_matches('/').ends_with(&nar_suffix)
+                        || path.ends_with(".nar.xz")
+                    {
+                        let head = format!(
+                            "HTTP/1.1 200 OK\r\nContent-Length: {}\r\nContent-Type: application/x-xz\r\nConnection: close\r\n\r\n",
+                            nar_xz.len()
+                        );
+                        let _ = sock.write_all(head.as_bytes()).await;
+                        let _ = sock.write_all(&nar_xz).await;
+                    } else {
+                        let _ = sock
+                            .write_all(b"HTTP/1.1 404 Not Found\r\nContent-Length: 0\r\nConnection: close\r\n\r\n")
+                            .await;
+                    }
+                    let _ = sock.flush().await;
+                });
+            }
+        });
+
+        format!("http://{addr}")
+    }
+
+    /// Guarantee #2: two DISTINCT store paths requested concurrently both
+    /// converge (both become valid), AND their upstream narinfo fetches overlap
+    /// rather than serialize. The narinfo handler holds a shared gauge across a
+    /// delay; if creation for distinct hashes ran under one global lock (the old
+    /// behavior), the second fetch could not start until the first finished and
+    /// the gauge would peak at 1. With per-hash single-flight the two creations
+    /// proceed in parallel and the gauge peaks at 2.
+    #[tokio::test]
+    async fn distinct_paths_create_concurrently() {
+        let fx_a = make_fixture_with_payload("distinct concurrency payload A\n").await;
+        let fx_b = make_fixture_with_payload("distinct concurrency payload B\n").await;
+        assert_ne!(
+            fx_a.store_path_hash, fx_b.store_path_hash,
+            "test needs two distinct hashes"
+        );
+
+        let gauge = NarinfoGauge::default();
+        // A generous delay so the two narinfo handlers are guaranteed to be
+        // in-flight at the same time when creation is concurrent; the assertion
+        // is on max concurrency, not on wall-clock, so it is not timing-flaky.
+        let delay_ms = 400;
+        let url_a = spawn_upstream_narinfo_gated(
+            fx_a.narinfo_text.clone(),
+            nar_url_from(&fx_a.narinfo_text),
+            fx_a.nar_xz.clone(),
+            gauge.clone(),
+            delay_ms,
+        )
+        .await;
+        let url_b = spawn_upstream_narinfo_gated(
+            fx_b.narinfo_text.clone(),
+            nar_url_from(&fx_b.narinfo_text),
+            fx_b.nar_xz.clone(),
+            gauge.clone(),
+            delay_ms,
+        )
+        .await;
+
+        let cfg_a = make_config(&fx_a, url_a);
+        let cfg_b = make_config(&fx_b, url_b);
+        let metrics = web::Data::new(crate::prometheus::initialize_metrics().unwrap());
+        // One shared registry: distinct hashes must not serialize on it.
+        let cache = Arc::new(NarInfoCache::new(16, std::time::Duration::from_secs(60)));
+        let registry = Arc::new(JobRegistry::new(cache));
+
+        let (ra, rb) = (registry.clone(), registry.clone());
+        let (ma, mb) = (metrics.clone(), metrics.clone());
+        let (ha, hb) = (fx_a.store_path_hash.clone(), fx_b.store_path_hash.clone());
+        let ta = tokio::spawn(async move {
+            match ra.attach(cfg_a, ma, &ha).await {
+                Attach::Live(body) => drain(body).await,
+                Attach::Parked(_) => Err(std::io::Error::other("unexpected Parked A")),
+            }
+        });
+        let tb = tokio::spawn(async move {
+            match rb.attach(cfg_b, mb, &hb).await {
+                Attach::Live(body) => drain(body).await,
+                Attach::Parked(_) => Err(std::io::Error::other("unexpected Parked B")),
+            }
+        });
+
+        let body_a = ta.await.unwrap().expect("client A body errored");
+        let body_b = tb.await.unwrap().expect("client B body errored");
+        assert_eq!(body_a, fx_a.golden_nar, "path A body != golden NAR");
+        assert_eq!(body_b, fx_b.golden_nar, "path B body != golden NAR");
+
+        // The narinfo fetches overlapped: distinct-hash creation is concurrent.
+        assert!(
+            gauge.max() >= 2,
+            "expected overlapping narinfo fetches (max concurrency >= 2), got {}",
+            gauge.max()
+        );
+
+        // Both paths converge in their respective stores.
+        for _ in 0..100 {
+            if path_is_valid(&fx_a) && path_is_valid(&fx_b) {
+                break;
+            }
+            tokio::time::sleep(std::time::Duration::from_millis(50)).await;
+        }
+        assert!(path_is_valid(&fx_a), "path A did not become valid");
+        assert!(path_is_valid(&fx_b), "path B did not become valid");
+    }
+
+    fn attach_name(a: &Attach) -> &'static str {
+        match a {
+            Attach::Live(_) => "Live",
+            Attach::Parked(_) => "Parked",
+        }
+    }
