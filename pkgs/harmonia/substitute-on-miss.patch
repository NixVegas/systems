+    /// Delete `fx`'s store path so a fresh `attach` is a genuine miss again.
+    /// Returns once the path is gone.
+    fn delete_store_path(fx: &Fixture) {
+        let entry = std::fs::read_dir(&fx.store_dir).ok().and_then(|mut d| {
+            d.find_map(|e| {
+                let e = e.ok()?;
+                let n = e.file_name().to_string_lossy().to_string();
+                n.starts_with(&fx.store_path_hash).then_some(n)
+            })
+        });
+        if let Some(name) = entry {
