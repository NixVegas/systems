+    /// Regression test for the creator-cancellation wedge.
+    ///
+    /// Reproduces the exact production window: the creator installs the per-hash
+    /// `InProgress` single-flight slot and begins the upstream narinfo RTT, a
+    /// same-hash waiter coalesces onto that shared creation, and THEN the
+    /// creator's request future is dropped (simulating a client disconnect during
+    /// the narinfo RTT — the actix handler awaits `attach` inline, so dropping the
+    /// returned future is exactly what a disconnect does).
+    ///
+    /// Simulation mechanism: the fake upstream delays the `.narinfo` reply, so the
+    /// creation stays in-flight. We drive the creator's `attach` future to
+    /// `Pending` with `futures::poll!` (guaranteeing it has taken the map lock,
+    /// installed `InProgress`, and issued the narinfo GET), spawn the waiter so it
+    /// coalesces onto the same `Shared`, then `drop` the creator's future. Because
+    /// the waiter keeps driving the `Shared`, the creation completes.
+    ///
+    /// Proves:
+    ///   (a) the waiter is served the correct golden NAR and the path becomes
+    ///       valid — convergence never depended on the creator;
+    ///   (b) the slot is finalized despite the creator being dropped: after the
+    ///       job finishes and we delete the path (GC), a fresh `attach` for the
+    ///       same hash RE-CREATES the job (issues a second upstream `.nar.xz`
+    ///       GET) instead of returning a stale terminal `Parked` off a wedged
+    ///       `InProgress(completed)` slot. Under the old bug the second fetch
+    ///       count would stay 1 and the fresh attach would 404 forever.
+    #[tokio::test]
+    async fn creator_cancel_still_finalizes_slot() {
+        use futures_util::poll;
+
+        let fx = make_fixture().await;
+        let nar_url = nar_url_from(&fx.narinfo_text);
+        // Delay the narinfo reply so the creation is guaranteed in-flight when we
+        // drop the creator. The upstream also counts .nar.xz GETs so we can prove
+        // a fresh fetch happens on re-create.
+        let (upstream_url, counter) = spawn_upstream_narinfo_delayed(
+            fx.narinfo_text.clone(),
+            nar_url,
+            fx.nar_xz.clone(),
+            300,
+        )
+        .await;
+        let cfg = make_config(&fx, upstream_url);
+        let metrics = web::Data::new(crate::prometheus::initialize_metrics().unwrap());
+        let cache = Arc::new(NarInfoCache::new(16, std::time::Duration::from_secs(60)));
+        let registry = Arc::new(JobRegistry::new(cache));
+
+        // 1. Creator: drive it once so it installs the InProgress slot and issues
+        //    the (delayed) narinfo GET, then leave it Pending.
+        let mut creator = Box::pin(registry.attach(
+            cfg.clone(),
+            metrics.clone(),
+            &fx.store_path_hash,
+        ));
+        let polled = poll!(creator.as_mut());
+        assert!(
+            polled.is_pending(),
+            "creator should still be mid-creation (narinfo RTT) — delay too short"
+        );
+
+        // 2. Waiter coalesces onto the same in-flight creation.
+        let waiter = {
+            let reg = registry.clone();
+            let cfg = cfg.clone();
+            let metrics = metrics.clone();
+            let hash = fx.store_path_hash.clone();
+            tokio::spawn(async move {
+                match reg.attach(cfg, metrics, &hash).await {
+                    Attach::Live(body) => drain(body).await,
+                    Attach::Parked(_) => Err(std::io::Error::other("waiter unexpectedly Parked")),
+                }
+            })
+        };
+        // Let the waiter reach its await on the shared creation.
+        tokio::time::sleep(std::time::Duration::from_millis(50)).await;
+
+        // 3. Drop the creator's request future mid-creation (client disconnect).
+        drop(creator);
+
+        // (a) The waiter is served the correct NAR and the path becomes valid.
+        let body = waiter.await.unwrap().expect("waiter body errored");
+        assert_eq!(body, fx.golden_nar, "waiter body != golden NAR");
+        for _ in 0..200 {
+            if path_is_valid(&fx) {
+                break;
+            }
+            tokio::time::sleep(std::time::Duration::from_millis(50)).await;
+        }
+        assert!(
+            path_is_valid(&fx),
+            "path did not become valid after creator-cancel"
+        );
+        assert_eq!(
+            counter.load(Ordering::SeqCst),
+            1,
+            "expected exactly one upstream nar.xz GET for the coalesced cohort"
+        );
+
+        // Let the fan-out finish and reap its Live slot (registry.remove on end).
+        tokio::time::sleep(std::time::Duration::from_millis(300)).await;
+
+        // (b) GC the path, then a fresh attach must RE-CREATE (fresh fetch), not
+        //     return a stale terminal Parked off a wedged InProgress slot.
+        delete_store_path(&fx);
+        assert!(!path_is_valid(&fx), "path should be gone after delete");
+
+        let reattach = registry
+            .attach(cfg.clone(), metrics.clone(), &fx.store_path_hash)
+            .await;
+        match reattach {
+            Attach::Live(body) => {
+                let b = drain(body).await.expect("re-created body errored");
+                assert_eq!(b, fx.golden_nar, "re-created body != golden NAR");
+            }
+            Attach::Parked(_) => panic!(
+                "slot was wedged: fresh attach returned stale Parked instead of re-creating"
+            ),
+        }
+        for _ in 0..200 {
+            if path_is_valid(&fx) {
+                break;
+            }
+            tokio::time::sleep(std::time::Duration::from_millis(50)).await;
+        }
+        assert!(path_is_valid(&fx), "re-created job did not make the path valid");
+        // A second, fresh upstream nar.xz GET proves the slot was finalized (not
+        // wedged): the registry re-resolved rather than serving a stale terminal.
+        assert_eq!(
+            counter.load(Ordering::SeqCst),
+            2,
+            "fresh attach after GC must issue a second upstream nar.xz GET (slot finalized)"
+        );
+    }
+
+    /// Like [`spawn_upstream`] but delays the `.narinfo` reply by
+    /// `narinfo_delay_ms` (nar.xz served immediately, no truncation) and still
+    /// returns a nar.xz GET counter. Used to widen the creation in-flight window
+    /// for the creator-cancellation regression test.
+    async fn spawn_upstream_narinfo_delayed(
+        narinfo_text: String,
+        nar_url: String,
+        nar_xz: Vec<u8>,
+        narinfo_delay_ms: u64,
+    ) -> (String, Arc<AtomicUsize>) {
+        let listener = TcpListener::bind("127.0.0.1:0").await.unwrap();
+        let addr = listener.local_addr().unwrap();
+        let counter = Arc::new(AtomicUsize::new(0));
+        let counter_task = counter.clone();
+        let nar_suffix = nar_url.trim_start_matches('/').to_string();
+
+        tokio::spawn(async move {
+            loop {
+                let (mut sock, _) = match listener.accept().await {
+                    Ok(s) => s,
+                    Err(_) => break,
+                };
+                let narinfo_text = narinfo_text.clone();
+                let nar_xz = nar_xz.clone();
+                let nar_suffix = nar_suffix.clone();
+                let counter = counter_task.clone();
+                tokio::spawn(async move {
+                    let mut buf = vec![0u8; 4096];
+                    let n = match sock.read(&mut buf).await {
+                        Ok(0) | Err(_) => return,
+                        Ok(n) => n,
+                    };
+                    let req = String::from_utf8_lossy(&buf[..n]);
+                    let path = req
+                        .lines()
+                        .next()
+                        .and_then(|l| l.split_whitespace().nth(1))
+                        .unwrap_or("/")
+                        .to_string();
+
+                    if path.ends_with(".narinfo") {
+                        if narinfo_delay_ms > 0 {
+                            tokio::time::sleep(std::time::Duration::from_millis(narinfo_delay_ms))
+                                .await;
+                        }
+                        let body = narinfo_text.as_bytes();
+                        let head = format!(
+                            "HTTP/1.1 200 OK\r\nContent-Length: {}\r\nContent-Type: text/x-nix-narinfo\r\nConnection: close\r\n\r\n",
+                            body.len()
+                        );
+                        let _ = sock.write_all(head.as_bytes()).await;
+                        let _ = sock.write_all(body).await;
+                    } else if path.trim_start_matches('/').ends_with(&nar_suffix)
+                        || path.ends_with(".nar.xz")
+                    {
+                        counter.fetch_add(1, Ordering::SeqCst);
+                        let head = format!(
+                            "HTTP/1.1 200 OK\r\nContent-Length: {}\r\nContent-Type: application/x-xz\r\nConnection: close\r\n\r\n",
+                            nar_xz.len()
+                        );
+                        let _ = sock.write_all(head.as_bytes()).await;
+                        let _ = sock.write_all(&nar_xz).await;
+                    } else {
+                        let _ = sock
+                            .write_all(b"HTTP/1.1 404 Not Found\r\nContent-Length: 0\r\nConnection: close\r\n\r\n")
+                            .await;
+                    }
+                    let _ = sock.flush().await;
+                });
+            }
+        });
+
+        (format!("http://{addr}"), counter)
+    }
+}
