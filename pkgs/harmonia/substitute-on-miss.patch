diff --git a/harmonia-cache/src/miss_warm.rs b/harmonia-cache/src/miss_warm.rs
new file mode 100644
index 0000000..d63332c
--- /dev/null
+++ b/harmonia-cache/src/miss_warm.rs
@@ -0,0 +1,208 @@
+//! Substitute-on-miss: when a lookup misses, the request is 301-redirected to
+//! the upstream cache (see narinfo.rs and the catch-all in main.rs) so the
+//! client never blocks on us. In parallel, this module resolves the hash part
+//! to a full store path — by fetching `<hash>.narinfo` from the upstream over
+//! HTTPS — and asks the real nix daemon to EnsurePath it in the background, so
+//! the next request for that path is served locally.
+
+use std::collections::HashSet;
+use std::path::Path;
+use std::sync::{Arc, LazyLock, Mutex};
+use std::time::Duration;
+
+use actix_web::{HttpRequest, HttpResponse, http, web};
+use harmonia_protocol::types::DaemonStore;
+use harmonia_store_core::store_path::StorePath;
+use harmonia_store_remote::DaemonClientBuilder;
+use tokio::io::{AsyncReadExt, AsyncWriteExt};
+use tokio::net::TcpStream;
+use tokio_rustls::TlsConnector;
+use tokio_rustls::rustls::{ClientConfig, RootCertStore};
+use tokio_rustls::rustls::pki_types::ServerName;
+
+use crate::config::Config;
+use crate::prometheus::PrometheusMetrics;
+
+/// Hash parts with a warm currently in flight (herd control).
+static IN_FLIGHT: LazyLock<Mutex<HashSet<String>>> =
+    LazyLock::new(|| Mutex::new(HashSet::new()));
+
+/// One shared rustls client config (Mozilla roots via webpki-roots).
+static TLS_CONFIG: LazyLock<Arc<ClientConfig>> = LazyLock::new(|| {
+    let roots = RootCertStore {
+        roots: webpki_roots::TLS_SERVER_ROOTS.to_vec(),
+    };
+    Arc::new(
+        ClientConfig::builder()
+            .with_root_certificates(roots)
+            .with_no_client_auth(),
+    )
+});
+
+const WARM_TIMEOUT: Duration = Duration::from_secs(15);
+const STORE_PREFIX: &str = "/nix/store/";
+
+/// The upstream URL a missed request should be redirected to. `path` is the
+/// incoming request path (e.g. `/abc123.narinfo` or `/nar/xxx.nar.xz`); the
+/// upstream serves the identical layout.
+pub(crate) fn redirect_target(upstream: &str, path: &str) -> String {
+    format!("{}{}", upstream.trim_end_matches('/'), path)
+}
+
+/// Catch-all default service: when substitute_on_miss is on, 302 any
+/// unmatched path to the same path upstream (this is how a post-narinfo NAR
+/// request in the upstream's `nar/<filehash>.nar.xz` format reaches upstream);
+/// otherwise fall back to a plain 404.
+pub(crate) async fn redirect_or_404(
+    req: HttpRequest,
+    config: web::Data<Config>,
+) -> HttpResponse {
+    if config.substitute_on_miss {
+        let location = redirect_target(&config.miss_upstream_url, req.path());
+        HttpResponse::Found()
+            .insert_header((http::header::LOCATION, location))
+            .insert_header(crate::cache_control_no_store())
+            .finish()
+    } else {
+        HttpResponse::NotFound().body("not found")
+    }
+}
+
+/// Fire-and-forget background warm: never blocks the caller, never errors.
+/// Spawns unless the feature is off or a warm for this hash is already running.
+pub(crate) fn maybe_warm(
+    config: &web::Data<Config>,
+    metrics: &web::Data<Arc<PrometheusMetrics>>,
+    hash: &str,
+) {
+    if !config.substitute_on_miss {
+        return;
+    }
+    metrics.narinfo_misses_total.inc();
+    if !IN_FLIGHT.lock().unwrap().insert(hash.to_string()) {
+        return; // already warming
+    }
+    metrics.warms_started_total.inc();
+    let hash = hash.to_string();
+    let upstream = config.miss_upstream_url.clone();
+    let socket = config.miss_daemon_socket.clone();
+    let metrics = metrics.clone();
+    tokio::spawn(async move {
+        let res = warm(&upstream, &socket, &hash).await;
+        IN_FLIGHT.lock().unwrap().remove(&hash);
+        match res {
+            Ok(path) => {
+                tracing::info!("substitute-on-miss: {path} is now valid");
+                metrics.warms_completed_total.inc();
+            }
+            Err(e) => {
+                tracing::warn!("substitute-on-miss: {hash}: {e}");
+                metrics.warms_failed_total.inc();
+            }
+        }
+    });
+}
+
+async fn warm(upstream: &str, socket: &Path, hash: &str) -> Result<String, String> {
+    let store_path = resolve_store_path(upstream, hash).await?;
+    let basename = store_path
+        .strip_prefix(STORE_PREFIX)
+        .ok_or_else(|| format!("resolved path not under {STORE_PREFIX}: {store_path}"))?;
+    let path = StorePath::from_bytes(basename.as_bytes())
+        .map_err(|e| format!("bad store path {store_path}: {e}"))?;
+
+    // The real nix daemon (not harmonia-daemon) substitutes the path from its
+    // configured substituters. connect_unix / ensure_path drive their log
+    // streams to completion when awaited.
+    let mut client = DaemonClientBuilder::new()
+        .connect_unix(socket)
+        .await
+        .map_err(|e| format!("daemon connect: {e}"))?;
+    client
+        .ensure_path(&path)
+        .await
+        .map_err(|e| format!("ensure_path: {e}"))?;
+    Ok(store_path)
+}
+
+/// HTTPS GET of `<upstream>/<hash>.narinfo`; returns the `StorePath:` field.
+async fn resolve_store_path(upstream: &str, hash: &str) -> Result<String, String> {
+    let body = tokio::time::timeout(WARM_TIMEOUT, https_get(upstream, &format!("/{hash}.narinfo")))
+        .await
+        .map_err(|_| "warm: upstream timeout".to_string())??;
+    parse_store_path(&body)
+}
+
+/// Minimal HTTPS/1.1 GET over tokio-rustls. Returns the response body on 200,
+/// errors otherwise. Only used for the tiny `.narinfo` fetch.
+async fn https_get(base: &str, path: &str) -> Result<String, String> {
+    let host = base
+        .strip_prefix("https://")
+        .ok_or_else(|| format!("miss_upstream_url must be https:// (got {base})"))?
+        .trim_end_matches('/');
+    let (host, _) = host.split_once('/').unwrap_or((host, ""));
+
+    let stream = TcpStream::connect((host, 443))
+        .await
+        .map_err(|e| format!("connect {host}:443: {e}"))?;
+    let server_name = ServerName::try_from(host.to_string())
+        .map_err(|e| format!("bad host {host}: {e}"))?;
+    let connector = TlsConnector::from(TLS_CONFIG.clone());
+    let mut tls = connector
+        .connect(server_name, stream)
+        .await
+        .map_err(|e| format!("tls handshake {host}: {e}"))?;
+
+    let req = format!(
+        "GET {path} HTTP/1.1\r\nHost: {host}\r\nConnection: close\r\nUser-Agent: harmonia-substitute-on-miss\r\n\r\n"
+    );
+    tls.write_all(req.as_bytes())
+        .await
+        .map_err(|e| format!("write: {e}"))?;
+    let mut buf = Vec::with_capacity(4096);
+    tls.read_to_end(&mut buf)
+        .await
+        .map_err(|e| format!("read: {e}"))?;
+
+    let text = String::from_utf8_lossy(&buf);
+    let (head, rest) = text
+        .split_once("\r\n\r\n")
+        .ok_or_else(|| "malformed HTTP response".to_string())?;
+    let status = head.lines().next().unwrap_or_default();
+    if !status.contains(" 200 ") {
+        return Err(format!("upstream: {status}"));
+    }
+    Ok(rest.to_string())
+}
+
+fn parse_store_path(narinfo: &str) -> Result<String, String> {
+    narinfo
+        .lines()
+        .find_map(|l| l.strip_prefix("StorePath: "))
+        .map(|s| s.trim().to_string())
+        .ok_or_else(|| "upstream narinfo: no StorePath field".to_string())
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn test_parse_store_path() {
+        let ni = "StorePath: /nix/store/abc123-hello-2.12\nURL: nar/x.nar.xz\n";
+        assert_eq!(parse_store_path(ni).unwrap(), "/nix/store/abc123-hello-2.12");
+        assert!(parse_store_path("URL: nar/x.nar.xz\n").is_err());
+    }
+
+    #[test]
+    fn test_redirect_target() {
+        assert_eq!(
+            redirect_target("https://cache.nixos.org", "/abc.narinfo"),
+            "https://cache.nixos.org/abc.narinfo"
+        );
+        assert_eq!(
+            redirect_target("https://cache.nixos.org/", "/nar/xyz.nar.xz"),
+            "https://cache.nixos.org/nar/xyz.nar.xz"
+        );
+    }
+}
