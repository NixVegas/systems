diff --git a/webapp/channels/src/utils/constants.tsx b/webapp/channels/src/utils/constants.tsx
index e379757074..5a6398e1af 100644
--- a/webapp/channels/src/utils/constants.tsx
+++ b/webapp/channels/src/utils/constants.tsx
@@ -1158,8 +1158,157 @@ export const LicenseLinks = {
     SOFTWARE_SERVICES_LICENSE_AGREEMENT: 'https://mattermost.com/pl/software-and-services-license-agreement',
     SOFTWARE_SERVICES_LICENSE_AGREEMENT_TEXT: 'Software Services and License Agreement',
     UNSUPPORTED: 'https://mattermost.com/pricing/',
+
+    // nixpkgs gold license links
+    SUPPORTED_WITH_NIXPKGS_GOLD: 'https://github.com/Jaculabilis/nixpkgs-gold',
+    SUPPORTED_WITH_NIXPKGS_GOLD_TRIAL: 'https://nixos.org/donate/',
+    SUPPORTED_WITH_NIXOS: 'https://nixos.org',
 };
 
+/**
+ * Valid build types.
+ */
+enum GoldBuildType {
+    GOLD = 'gold',
+    GOLD_TRIAL = 'gold-trial',
+    NIX = 'nix',
+    NONE = 'none'
+}
+
+// Pull the nix env out of the window variable. Normally this is provided by webpack.
+const nixEnv: Record<string, string|number|boolean|null> = Object.freeze(window.nixEnv || {});
+
+/**
+ * Returns the current nixpkgs gold build type.
+ * @returns GoldBuildType
+ */
+function getBuildType(): GoldBuildType {
+    if (parseInt(nixEnv.NIXPKGS_GOLD)) {
+        if (parseInt(nixEnv.NIXPKGS_GOLD_LICENSED)) {
+            return GoldBuildType.GOLD;
+        } else {
+            return GoldBuildType.GOLD_TRIAL;
+        }
+    } else if (nixEnv.NIX_STORE) {
+        return GoldBuildType.NIX;
+    } else {
+        return GoldBuildType.NONE;
+    }
+}
+
+/**
+ * Nixpkgs gold ads. This comes in as a newline separated string, split it and cache it.
+ */
+const NIXPKGS_GOLD_ADS: string[] = `${(nixEnv.NIXPKGS_GOLD_ADS || '')}`.trim().split("\n").map(ad => {
+    return ad.replace(/\$out/, nixEnv.out || '$out')
+});
+
+/**
+ * Gets the nixpkgs gold trial message.
+ * @param intervalMs the interval for changing messages
+ * @returns string
+ */
+let lastMessage_: string = '';
+let lastTime_: Time|null = null;
+function getGoldTrialMessage(intervalMs: number = 30 * 1000): string {
+    // Ratelimit how often nixpkgs gold(tm) messages change
+    const now = new Date();
+    if (!lastTime_ || now.getTime() > lastTime_.getTime() + intervalMs) {
+        lastMessage_ = NIXPKGS_GOLD_ADS[Math.floor(Math.random() * NIXPKGS_GOLD_ADS.length)] || nixEnv.NIXPKGS_GOLD_AD || '';
+        lastTime_ = now;
+    }
+
+    return lastMessage_;
+}
+
+/**
+ * Gets the nixpkgs gold edition.
+ * @returns string
+ */
+export function getEdition(): string {
+    switch (getBuildType()) {
+        case GoldBuildType.GOLD:
+            return 'GOLD EDITION';
+        case GoldBuildType.GOLD_TRIAL:
+            return 'GOLD TRIAL EDITION';
+        case GoldBuildType.NIX:
+            return 'NIX EDITION';
+        default:
+            return 'FREE EDITION';
+    }
+}
+
+/**
+ * Gets the nixpkgs gold edition name.
+ * @returns string
+ */
+export function getEditionName(): string {
+    switch (getBuildType()) {
+        case GoldBuildType.GOLD:
+            return 'nixpkgs gold';
+        case GoldBuildType.GOLD_TRIAL:
+            return 'nixpkgs gold free trial';
+        case GoldBuildType.NIX:
+            return 'nixpkgs';
+        default:
+            return 'unsupported';
+    }
+}
+
+/**
+ * Gets the link for the nixpkgs gold edition.
+ * @returns string
+ */
+export function getEditionLink(): string {
+    switch (getBuildType()) {
+        case GoldBuildType.GOLD:
+            return LicenseLinks.SUPPORTED_WITH_NIXPKGS_GOLD;
+        case GoldBuildType.GOLD_TRIAL:
+            return LicenseLinks.SUPPORTED_WITH_NIXPKGS_GOLD_TRIAL;
+        case GoldBuildType.NIX:
+            return LicenseLinks.SUPPORTED_WITH_NIXOS;
+        default:
+            return LicenseLinks.UNSUPPORTED;
+    }
+}
+
+/**
+ * Gets the nixpkgs gold edition message.
+ * @returns string
+ */
+export function getEditionMessage(): string {
+    switch (getBuildType()) {
+        case GoldBuildType.GOLD:
+        case GoldBuildType.NIX: {
+            if (nixEnv.out) {
+                return ` Proudly hosted at ${nixEnv.out}`;
+            } else {
+                return '';
+            }
+        }
+        case GoldBuildType.GOLD_TRIAL:
+            return ' ' + getGoldTrialMessage();
+        default:
+            return '';
+    }
+}
+
+/**
+ * Gets a color for the edition theme.
+ * @returns rgba CSS value
+ */
+export function getEditionColor(): string {
+    switch (getBuildType()) {
+        case GoldBuildType.GOLD:
+        case GoldBuildType.GOLD_TRIAL:
+            return 'rgba(var(--away-indicator-rgb), 0.3)';
+        case GoldBuildType.NIX:
+            return 'rgba(var(--dnd-indicator-rgb), 0.3)';
+        default:
+            return 'rgba(var(--sidebar-text-rgb), 0.08)';
+    }
+}
+
 export const MattermostLink = 'https://mattermost.com/';
 
 export const BillingSchemes = {
diff --git a/webapp/channels/webpack.config.js b/webapp/channels/webpack.config.js
index 3b281a938a..92efe509d7 100644
--- a/webapp/channels/webpack.config.js
+++ b/webapp/channels/webpack.config.js
@@ -389,8 +389,15 @@ if (DEV) {
     env.NODE_ENV = JSON.stringify('production');
 }
 
+// Allow certain Nix variables into the build
+const nixEnv = Object.fromEntries(
+    Object.entries(process.env)
+        .filter(([key, val]) => key.match(/(^NIXPKGS_|^NIX_STORE$|^out$)/))
+        .map(([key, val]) => [key, JSON.stringify(val)])
+);
 config.plugins.push(new webpack.DefinePlugin({
     'process.env': env,
+    'window.nixEnv': nixEnv,
 }));
 
 if (targetIsDevServer) {
